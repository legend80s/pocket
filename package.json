{
  "name": "@legend80s/pelican",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "version": "0.0.6",
  "description": "Alias pocket: A shell alias library that follows the shadcn approach — installed via copy source code, not dependency. Feel free to customize it — you own the code, just like shadcn.",
  "main": "index.js",
  "scripts": {
    "test": "node --test",
    "typecheck": "tsgo --noEmit",
    "pub:patch": "npm version patch",
    "pub:minor": "npm version minor",
    "pub:major": "npm version major",
    "preversion": "npm test && npm run typecheck",
    "postversion": "npm publish && git push && git push --tags"
  },
  "bin": {
    "pelican": "bin/pocket.js",
    "鹈鹕": "bin/pocket.js",
    "tihu": "bin/pocket.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "keywords": [
    "alias",
    "shell",
    "cli",
    "npm",
    "zsh",
    "bash",
    "productivity",
    "shadcn"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/prompts": "^2.4.9"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  }
}
